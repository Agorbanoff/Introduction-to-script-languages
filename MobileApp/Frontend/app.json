{
  "expo": {
    "name": "firstProject",
    "slug": "firstProject",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "jsEngine": "jsc",
    "splash": {
      "image": "./Images/homePagePhoto.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./Images/breakfast1.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./Images/snack1.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ]
  }
}
